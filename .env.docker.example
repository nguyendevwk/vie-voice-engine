# Docker Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (Required)
# =============================================================================
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=qwen/qwen3-32b
LLM_USE_EXTENDED=true
LLM_AUTO_REGISTER_TASK_HANDLERS=true

# Realtime pipeline tuning
PIPELINE_LLM_HISTORY_WINDOW=8
PIPELINE_MIN_TTS_CHUNK_CHARS=20
PIPELINE_TTS_OVERLAP_ENABLED=true
PIPELINE_MAX_PLAYBACK_WAIT_S=1.5

# =============================================================================
# ASR Configuration
# =============================================================================
ASR_USE_ONNX=true
ASR_DEVICE=cpu

# =============================================================================
# TTS Configuration
# =============================================================================
# Backend: auto, vieneu, qwen, edge
TTS_BACKEND=vieneu
TTS_SPEECH_RATE=1.25
TTS_DEVICE=cpu

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WARMUP=true

# =============================================================================
# Debug & Logging
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO
