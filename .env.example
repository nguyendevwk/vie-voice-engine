# Voice Assistant Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration
# =============================================================================
# Groq API (recommended for speed)
GROQ_API_KEY=your-groq-api-key-here

# OpenAI API (alternative)
# OPENAI_API_KEY=your-openai-api-key-here

# LLM Provider: groq, openai, local
LLM_PROVIDER=groq

# LLM Model (optional - uses default if not set)
# LLM_MODEL=qwen/qwen3-32b

# LLM Temperature (0.0-1.0, higher = more creative)
# LLM_TEMPERATURE=0.8

# Enable extended LLM runtime (task routing via llm_base/llm_extended)
# LLM_USE_EXTENDED=true

# Auto-register built-in task handlers (qa, support, task manager, etc.)
# LLM_AUTO_REGISTER_TASK_HANDLERS=true

# Custom system prompt (optional - overrides default personality)
# LLM_SYSTEM_PROMPT=Your custom prompt here

# =============================================================================
# Device Configuration
# =============================================================================
# ASR device: auto, cpu, cuda, cuda:0, cuda:1
ASR_DEVICE=auto

# TTS device: cpu, cuda:0
TTS_DEVICE=cuda:0

# =============================================================================
# Debug & Logging
# =============================================================================
# Enable debug mode (verbose logging)
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# Server Configuration
# =============================================================================
# API server host and port
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Run warmup inference on startup (reduces first-request latency)
SERVER_WARMUP=true

# =============================================================================
# Session Configuration
# =============================================================================
# Session timeout in seconds (default: 30 minutes)
SESSION_TIMEOUT=1800

# Maximum conversation history per session
MAX_HISTORY_LENGTH=50

# Enable session persistence (save to disk)
SESSION_PERSISTENCE=false

# Session storage path
SESSION_STORAGE_PATH=./sessions

# =============================================================================
# TTS Backend
# =============================================================================
# TTS Backend options:
#   - auto: Auto-select best available (remote > local > qwen > edge)
#   - vieneu_remote: VieNeu-TTS remote server (RECOMMENDED for Docker, optimal latency)
#   - vieneu: VieNeu-TTS local mode (CPU-friendly, offline)
#   - qwen: Qwen-TTS (GPU, high quality, voice cloning)
#   - edge: Edge-TTS (online fallback, free)
TTS_BACKEND=vieneu_remote

# Default speaker (must match a key in voice_assistant/data/ref_info.json)
# Available: yen_nhi, my_van, ai_vy, an_nhi, dieu_linh, khanh_toan, tran_lam, nsnd_ha_phuong, nsnd_kim_cuc
TTS_DEFAULT_SPEAKER=yen_nhi

# TTS Speech Rate (1.0 = normal, 1.25 = faster - limited for edge-tts stability)
TTS_SPEECH_RATE=1.25

# =============================================================================
# VieNeu-TTS Remote Mode (RECOMMENDED for Docker - optimal latency)
# =============================================================================
# 🚀 Remote mode: lightweight client (~50MB), server does heavy lifting
# Perfect for Docker containers, low-end hardware, web applications
# Latency: typically 100-500ms (localhost, no network overhead)

# IMPORTANT: 
# - For Docker Desktop (Mac/Windows): use host.docker.internal
# - For Docker on Linux: use host network mode or 172.17.0.1
# - For local dev (no Docker): use localhost

# Docker Desktop (Mac/Windows):
VIENEU_REMOTE_API_BASE=http://host.docker.internal:23333/v1

# Docker on Linux (uncomment and use):
# VIENEU_REMOTE_API_BASE=http://172.17.0.1:23333/v1

# Local development (no Docker):
# VIENEU_REMOTE_API_BASE=http://localhost:23333/v1

VIENEU_REMOTE_MODEL_ID=pnnbao-ump/VieNeu-TTS

# =============================================================================
# VieNeu-TTS Local Mode (alternative - offline capable)
# =============================================================================
# If you want to run TTS locally instead of remote:
# TTS_BACKEND=vieneu
# VIENEU_MODE=turbo
# VIENEU_MODEL_BACKBONE=pnnbao-ump/VieNeu-TTS-v2-Turbo-GGUF
# VIENEU_MODEL_DECODER=pnnbao-ump/VieNeu-Codec
# VIENEU_MODEL_ENCODER=pnnbao-ump/VieNeu-Codec

# Use ONNX for faster TTS inference (requires ONNX model)
TTS_USE_ONNX=true

# Enable TTS streaming (chunk-by-chunk output)
TTS_STREAMING=true

# HuggingFace Hub Token (for downloading gated models)
HF_HUB_TOKEN=your_token_here

# ASR Backend Configuration
# Prefer ONNX for speed and simplicity, PyTorch CUDA for maximum quality
ASR_USE_ONNX=true
ASR_USE_PYTORCH_CUDA=false

# Pipeline Timeouts (prevent hanging)
PIPELINE_ASR_TIMEOUT=10
PIPELINE_LLM_TIMEOUT=30
PIPELINE_TTS_TIMEOUT=15
PIPELINE_TOTAL_TIMEOUT=60

# Real-time tuning
# Number of recent messages passed to LLM context (lower = faster)
PIPELINE_LLM_HISTORY_WINDOW=8
# Minimum characters to dispatch a TTS chunk (lower = earlier speech)
PIPELINE_MIN_TTS_CHUNK_CHARS=20
# Enable overlapping TTS synthesis while LLM is still streaming
PIPELINE_TTS_OVERLAP_ENABLED=true
# Max extra wait (seconds) after synthesis before unmuting microphone
PIPELINE_MAX_PLAYBACK_WAIT_S=1.5

# =============================================================================
# LLM System Prompt for TTS Optimization
# =============================================================================
# The system prompt is optimized for TTS output:
# - No markdown, code blocks, lists
# - Short sentences (1-3 per response)
# - Conversational tone
# - Clear numbers and abbreviations
# - Proper punctuation for speech
# 
# To customize, uncomment and modify:
# LLM_SYSTEM_PROMPT=Your custom prompt here
